---
layout: none
---
[
  {% for post in site.posts %}
  {
    "title": "{{ post.title | escape }}",
    "url": "{{ post.url | relative_url }}",
    "date": "{{ post.date | date: '%d %B %Y' }}",
    "category": "{{ post.category }}",
    "tags": "{{ post.tags | join: ' ' }}",
    "excerpt": "{{ post.excerpt | strip_html | truncate: 200 | escape }}"
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
